{
  "version": 2,
  "routes": [
    {
      "src": "/install",
      "dest": "/api/install.js",
      "methods": ["GET", "POST"]
    },
    {
      "src": "/lead(/.*)?",
      "dest": "/api/lead.js",
      "methods": ["GET", "POST"]
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js",
      "methods": ["GET", "POST"]
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "" },
        { "key": "Content-Security-Policy", "value": "" }
      ]
    }
  ]
}
